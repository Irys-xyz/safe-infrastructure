# {{ ansible_managed }}
# Repo-root .env for the Irys Mainnet (chain 3282) Safe stack. Rendered on the
# host by ansible/irys-safe.yml; edit the Ansible variables, not this file.

# Irys Mainnet execution RPC. The indexer's eth_getLogs load hits public rate
# limits; use a dedicated endpoint for production (RUNBOOK section 10).
RPC_NODE_URL={{ irys_rpc_node_url }}

# Host port for nginx (admin + APIs). The wallet UI is also published on 8080.
REVERSE_PROXY_PORT={{ irys_reverse_proxy_port }}

# Client Gateway path baked into the UI's static export at build time. Default is the relative
# /cgw, so the UI's gateway calls always share the page's origin (no CORS) whatever host:port or
# domain the stack is reached on. Set irys_ui_gateway_url to an absolute URL only for a Client
# Gateway on a different origin. Consumed by scripts/run_locally_podman.sh (build-arg) and the
# compose ui build.
UI_GATEWAY_URL={{ irys_ui_gateway_url }}

# Fixes the compose project name so container names are stable (e.g.
# {{ irys_project_name }}_cfg-web_1), which configure_irys.sh and the unit's
# `docker compose down` rely on.
COMPOSE_PROJECT_NAME={{ irys_project_name }}

# Service image tags. Pin to exact versions for reproducibility (RUNBOOK section 10).
TXS_VERSION={{ irys_txs_version }}
CFG_VERSION={{ irys_cfg_version }}
CGW_VERSION={{ irys_cgw_version }}
EVENTS_VERSION={{ irys_events_version }}
{% if irys_cfg_superuser_username is defined and irys_cfg_superuser_password is defined %}

# Config Service admin, created non-interactively on first start.
CFG_SUPERUSER_USERNAME={{ irys_cfg_superuser_username }}
CFG_SUPERUSER_EMAIL={{ irys_cfg_superuser_email | default('admin@example.com') }}
CFG_SUPERUSER_PASSWORD={{ irys_cfg_superuser_password }}
{% endif %}
{% if irys_txs_superuser_username is defined and irys_txs_superuser_password is defined %}

# Transaction Service admin, created non-interactively on first start.
TXS_SUPERUSER_USERNAME={{ irys_txs_superuser_username }}
TXS_SUPERUSER_EMAIL={{ irys_txs_superuser_email | default('admin@example.com') }}
TXS_SUPERUSER_PASSWORD={{ irys_txs_superuser_password }}
{% endif %}
