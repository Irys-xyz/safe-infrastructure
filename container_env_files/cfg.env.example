PYTHONDONTWRITEBYTECODE=true

SECRET_KEY=__CHANGE_ME__

DEBUG=false
ROOT_LOG_LEVEL=INFO

# Public hostname(s) the service answers on, plus the internal names it is reached by
# (the nginx proxy and localhost healthchecks). Never "*" in production: with DEBUG on it
# turns every error into a public traceback, and it disables the Host-header guard. Ansible
# overwrites this from irys_safe_domain on deploy; set it here too for manual provisioning.
DJANGO_ALLOWED_HOSTS="__SAFE_DOMAIN__,nginx,localhost,127.0.0.1"

GUNICORN_BIND_PORT=8001

DOCKER_NGINX_VOLUME_ROOT=/nginx

GUNICORN_BIND_SOCKET=unix:${DOCKER_NGINX_VOLUME_ROOT}/gunicorn.socket

# NGINX_HOST_PORT=8080

NGINX_ENVSUBST_OUTPUT_DIR=/etc/nginx/

POSTGRES_USER=postgres
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_NAME=postgres
POSTGRES_HOST=cfg-db
POSTGRES_PORT=5432

DOCKER_WEB_VOLUME=.:/app

GUNICORN_WEB_RELOAD=false

DJANGO_SUPERUSER_PASSWORD=__CHANGE_ME__
DJANGO_SUPERUSER_USERNAME=root
DJANGO_SUPERUSER_EMAIL=test@example.com
DJANGO_OTP_ADMIN=false

DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage

FORCE_SCRIPT_NAME=/cfg/

CGW_URL=http://nginx:8000/cgw
CGW_AUTH_TOKEN=__CHANGE_ME__

# The public origin, plus http://localhost:8000 so the admin stays usable over an SSH
# local-forward (the admin is 403'd publicly by the Caddy proxy).
CSRF_TRUSTED_ORIGINS="https://__SAFE_DOMAIN__,http://localhost:8000"

MEDIA_URL = "https://__SAFE_DOMAIN__/cfg/media/"
